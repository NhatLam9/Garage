<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:ignore="HardcodedText, Typos">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_include">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <include layout="@layout/layout_header" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_map_garage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="📍 TÌM TIỆM SỬA XE"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    app:backgroundTint="@color/colorPrimary"
                    android:textColor="@color/text_white" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diy_diary"
                    android:textColor="@color/text_white"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Chưa có lịch trình cá nhân nào.\nẤn nút [+] màu cam để thêm việc!"
                android:textColor="@color/text_gray"
                android:textSize="14sp"
                android:layout_marginVertical="24dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_todo_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SẢN PHẨM ĐỀ XUẤT"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Các thương hiệu phụ tùng hiệu suất cao"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView android:layout_width="260dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="12dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOT DEAL" android:textColor="@color/colorPrimary" android:textSize="10sp" android:textStyle="bold" android:background="#1AFFFF00" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nhớt Motul 300V" android:textColor="@color/text_white" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bảo vệ động cơ tối đa cho xe tay côn" android:textColor="@color/text_gray" android:textSize="11sp" android:layout_marginBottom="8dp"/>
                            <ImageView android:layout_width="match_parent" android:layout_height="120dp" android:scaleType="fitCenter" android:src="@drawable/motul" android:layout_marginBottom="8dp"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_buy_motul"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="🛒 TÌM MUA NGAY"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:cornerRadius="8dp"
                                app:backgroundTint="#33FFFFFF"
                                android:textColor="@color/text_white"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="260dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="12dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ĐÁNH GIÁ CAO" android:textColor="@color/status_green" android:textSize="10sp" android:textStyle="bold" android:background="#1A00FF00" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lốp Pirelli Rosso" android:textColor="@color/text_white" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bám đường cực tốt trong điều kiện trời mưa" android:textColor="@color/text_gray" android:textSize="11sp" android:layout_marginBottom="8dp"/>
                            <ImageView android:layout_width="match_parent" android:layout_height="120dp" android:scaleType="fitCenter" android:src="@drawable/pireli" android:layout_marginBottom="8dp"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_buy_pirelli"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="🛒 TÌM MUA NGAY"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:cornerRadius="8dp"
                                app:backgroundTint="#33FFFFFF"
                                android:textColor="@color/text_white"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="260dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="12dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PREMIUM" android:textColor="#FF5252" android:textSize="10sp" android:textStyle="bold" android:background="#1AFF0000" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Má phanh Brembo" android:textColor="@color/text_white" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hiệu suất phanh an toàn tuyệt đối" android:textColor="@color/text_gray" android:textSize="11sp" android:layout_marginBottom="8dp"/>
                            <ImageView android:layout_width="match_parent" android:layout_height="120dp" android:scaleType="fitCenter" android:src="@drawable/brembo" android:layout_marginBottom="8dp"/>
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_buy_brembo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="🛒 TÌM MUA NGAY"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                app:cornerRadius="8dp"
                                app:backgroundTint="#33FFFFFF"
                                android:textColor="@color/text_white"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DANH MỤC PHỤ TÙNG"
                android:textColor="@color/text_white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhấn để xem top các sản phẩm được tin dùng nhất"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView android:id="@+id/btn_product_oil" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="8dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="Dầu nhớt" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/btn_product_coolant" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="8dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="Nước mát" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/btn_product_brake_pad" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_marginStart="6dp" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="8dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="Má phanh" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="24dp">

                <com.google.android.material.card.MaterialCardView android:id="@+id/btn_product_brake_fluid" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="8dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="Dầu thắng" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/btn_product_oil_filter" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="8dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="Lọc nhớt" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/btn_product_air_filter" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_marginStart="6dp" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="8dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="Lọc gió" android:textColor="@color/text_white" android:textSize="13sp" android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_doc_todo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/text_white"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_include"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Thêm Lịch Trình" />

    <include
        android:id="@+id/bottom_nav_include"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>