<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:ignore="HardcodedText, Typos">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <include layout="@layout/layout_header" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tech_search_title"
                android:textColor="@color/text_gray"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="25dp"
                app:strokeColor="@color/stroke_color"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="16sp"
                        android:layout_marginEnd="12dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tech_search_hint"
                        android:textColor="@color/text_gray"
                        android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ref_library"
                android:textColor="@color/text_white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/stroke_color"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔌"
                            android:textSize="24sp"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/electrical_diagrams"
                            android:textColor="@color/text_white"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/full_schematics"
                            android:textColor="@color/text_gray"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/stroke_color"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔧"
                            android:textSize="24sp"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/torque_specs"
                            android:textColor="@color/text_white"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/critical_fasteners"
                            android:textColor="@color/text_gray"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/stroke_color"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/icon_interval"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱️"
                        android:textSize="24sp"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/icon_interval"
                        android:layout_centerVertical="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/service_intervals"
                            android:textColor="@color/text_white"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/maintenance_milestones"
                            android:textColor="@color/colorPrimary"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="@color/text_white"
                        android:textSize="18sp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView android:layout_width="310dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_sys_focus" android:textColor="@color/status_blue" android:textSize="10sp" android:textStyle="bold" android:background="#1A00BFFF" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_dohc_title" android:textColor="@color/text_white" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_dohc_desc" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_marginBottom="16dp"/>
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="280dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/dohc"/>
                            </RelativeLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="310dp" android:layout_height="match_parent" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_tire_label" android:textColor="@color/status_green" android:textSize="10sp" android:textStyle="bold" android:background="#1A00FF00" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_tire_title" android:textColor="@color/text_white" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_tire_desc" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_marginBottom="16dp"/>
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="280dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/pireli"/>
                            </RelativeLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="310dp" android:layout_height="match_parent" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_oil_label" android:textColor="@color/colorPrimary" android:textSize="10sp" android:textStyle="bold" android:background="#1AFFFF00" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_oil_title" android:textColor="@color/text_white" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_oil_desc" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_marginBottom="16dp"/>
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="280dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/motul"/>
                            </RelativeLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="310dp" android:layout_height="match_parent" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_air_label" android:textColor="#00FFFF" android:textSize="10sp" android:textStyle="bold" android:background="#1A00FFFF" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_air_title" android:textColor="@color/text_white" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_air_desc" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_marginBottom="16dp"/>
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="280dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/air"/>
                            </RelativeLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="310dp" android:layout_height="match_parent" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_brake_label" android:textColor="#FF5252" android:textSize="10sp" android:textStyle="bold" android:background="#1AFF0000" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_brake_title" android:textColor="@color/text_white" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_brake_desc" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_marginBottom="16dp"/>
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="280dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/brembo"/>
                            </RelativeLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="310dp" android:layout_height="match_parent" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp" android:layout_marginEnd="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_spark_label" android:textColor="#E040FB" android:textSize="10sp" android:textStyle="bold" android:background="#1AAA00FF" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_spark_title" android:textColor="@color/text_white" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_spark_desc" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_marginBottom="16dp"/>
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="280dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/bugi"/>
                            </RelativeLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView android:layout_width="310dp" android:layout_height="match_parent" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:strokeColor="@color/stroke_color" app:strokeWidth="1dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_coolant_label" android:textColor="#00BFFF" android:textSize="10sp" android:textStyle="bold" android:background="#1A00BFFF" android:paddingHorizontal="6dp" android:paddingVertical="2dp" android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_coolant_title" android:textColor="@color/text_white" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/docs_rec_coolant_desc" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_marginBottom="16dp"/>
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="280dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:src="@drawable/engineice"/>
                            </RelativeLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diy_diary"
                    android:textColor="@color/text_white"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Chưa có lịch trình cá nhân nào.\nẤn nút [+] màu cam để thêm việc!"
                android:textColor="@color/text_gray"
                android:textSize="14sp"
                android:layout_marginVertical="32dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_todo_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="80dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_doc_todo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/text_white"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Thêm Lịch Trình" />

    <include
        android:id="@+id/bottom_nav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>