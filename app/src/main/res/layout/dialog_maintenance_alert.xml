<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1E1212"
    app:cardCornerRadius="20dp"
    app:strokeColor="#FF5252"
    app:strokeWidth="1.5dp"
    android:layout_margin="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tv_alert_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CẢNH BÁO BẢO DƯỠNG"
            android:textColor="#FF5252"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_alert_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Linh kiện của bạn đã chạm ngưỡng giới hạn nguy hiểm, cần tiến hành sửa chữa hoặc thay thế ngay lập tức!"
            android:textColor="@color/text_white"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_close_alert"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="ĐÃ HIỂU &amp; KIỂM TRA XE"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:backgroundTint="#FF5252"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>